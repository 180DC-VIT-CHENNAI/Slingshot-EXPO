generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  sessions  Session[]
}

model Session {
  id        String   @id @default(uuid())
  playerId  String
  score     Int
  comment   String
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id])

  @@index([createdAt])
  @@index([playerId])
}
